@{
    Layout = "_Layout";
    ViewData["Title"] = "商品列表";
    var isCustomer = User.IsInRole(ECommerce.Shared.Constants.AuthConstants.Roles.User);
}

<div id="productsApp" v-cloak>
    <div class="py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h1 class="h3 mb-1">商品列表</h1>
                <p class="text-muted mb-0">共 {{ pagination.totalCount }} 件商品</p>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-3">
                <div class="card mb-3">
                    <div class="card-header">
                        <h2 class="h6 mb-0">搜索</h2>
                    </div>
                    <div class="card-body">
                        <div class="input-group">
                            <input type="text" class="form-control" v-model="keyword" placeholder="搜索商品名称..." v-on:keyup.enter="loadProducts(1)">
                            <button class="btn btn-outline-primary" type="button" v-on:click="loadProducts(1)">
                                <i class="bi bi-search"></i>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h2 class="h6 mb-0">商品分类</h2>
                        <button v-if="selectedCategoryId" type="button" class="btn btn-sm btn-link p-0 text-muted" v-on:click="clearCategory">
                            清除
                        </button>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                    :class="{ active: !selectedCategoryId }"
                                    v-on:click="selectCategory(null)">
                                <span><i class="bi bi-grid me-1"></i> 全部分类</span>
                            </button>
                            <template v-for="cat in categoryTree" :key="cat.categoryId">
                                <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                        :class="{ active: selectedCategoryId === cat.categoryId }"
                                        v-on:click="selectCategory(cat.categoryId)">
                                    <span><i class="bi bi-folder me-1"></i> {{ cat.name }}</span>
                                    <span v-if="cat.children && cat.children.length > 0" class="text-muted small">
                                        <i class="bi bi-chevron-down"></i>
                                    </span>
                                </button>
                                <template v-if="cat.children && cat.children.length > 0">
                                    <button type="button"
                                            class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                            :class="{ active: selectedCategoryId === sub.categoryId }"
                                            v-for="sub in cat.children" :key="sub.categoryId"
                                            style="padding-left: 2.5rem;"
                                            v-on:click="selectCategory(sub.categoryId)">
                                        <span><i class="bi bi-tag me-1"></i> {{ sub.name }}</span>
                                    </button>
                                </template>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-9">
                <div v-if="loading" class="text-center py-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">加载中...</span>
                    </div>
                </div>

                <div v-else-if="products.length === 0" class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size: 3rem;"></i>
                    <p class="text-muted mt-3">暂无符合条件的商品</p>
                </div>

                <div v-else class="row g-3">
                    <div v-for="product in products" :key="product.productId" class="col-6 col-md-4 col-xl-3">
                        <a :href="'/products/' + product.productId" class="card text-decoration-none h-100 product-card">
                            <div class="position-relative">
                                <img :src="product.mainImage" class="card-img-top" alt="商品图片" style="height: 200px; object-fit: cover;">
                                <span v-if="product.status === 2" class="badge bg-warning position-absolute top-2 end-2">预售</span>
                            </div>
                            <div class="card-body">
                                <h5 class="card-title h6 mb-2 text-truncate" :title="product.name">{{ product.name }}</h5>
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="text-danger fw-bold">¥{{ product.priceMin.toFixed(2) }}</span>
                                    <span class="text-muted small">销量 {{ product.salesCount }}</span>
                                </div>
                                <div class="d-flex align-items-center">
                                    <div class="text-warning small">
                                        <i v-for="n in 5" :key="n" class="bi"
                                           :class="n <= Math.round(product.avgRating) ? 'bi-star-fill' : 'bi-star'"></i>
                                    </div>
                                    <span class="text-muted small ms-1">{{ product.avgRating.toFixed(1) }}</span>
                                </div>
                            </div>
                        </a>
                    </div>
                </div>

                <nav v-if="pagination.totalPages > 1" aria-label="商品分页" class="mt-4">
                    <ul class="pagination justify-content-center">
                        <li class="page-item" :class="{ disabled: pagination.pageIndex === 1 }">
                            <button class="page-link" v-on:click="loadProducts(pagination.pageIndex - 1)">上一页</button>
                        </li>
                        <li class="page-item" :class="{ active: pagination.pageIndex === page }" v-for="page in pageNumbers" :key="page">
                            <button class="page-link" v-on:click="loadProducts(page)">{{ page }}</button>
                        </li>
                        <li class="page-item" :class="{ disabled: pagination.pageIndex >= pagination.totalPages }">
                            <button class="page-link" v-on:click="loadProducts(pagination.pageIndex + 1)">下一页</button>
                        </li>
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="~/js/products.js" asp-append-version="true"></script>
}
