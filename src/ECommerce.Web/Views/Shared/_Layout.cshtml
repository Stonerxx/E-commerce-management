<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 电商管理系统</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ECommerce.Web.styles.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" href="/">电商管理系统</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar" aria-expanded="false" aria-label="切换导航">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                        <li class="nav-item"><a class="nav-link" href="/">首页</a></li>
                        <li class="nav-item"><a class="nav-link" href="/addresses">收货地址</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin">后台首页</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/users">用户管理</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/permissions">权限管理</a></li>
                        <li class="nav-item"><a class="nav-link" href="/admin/operation-logs">操作日志</a></li>
                    </ul>
                    <div class="d-flex gap-2">
                        <a class="btn btn-sm btn-outline-primary" href="/account/login">登录</a>
                        <a class="btn btn-sm btn-primary" href="/account/register">注册</a>
                    </div>
                </div>
            </div>
        </nav>
    </header>
    <main class="container py-4">
        @RenderBody()
    </main>

    <footer class="border-top text-muted py-3">
        <div class="container">
            &copy; 2026 - 电商管理系统
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
