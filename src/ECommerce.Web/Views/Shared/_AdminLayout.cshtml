<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 后台管理</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header class="border-bottom shadow-sm">
        <nav class="navbar navbar-expand-lg navbar-light bg-white">
            <div class="container-fluid">
                <a class="navbar-brand fw-semibold" href="/admin">后台管理</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNavbar"
                        aria-controls="adminNavbar" aria-expanded="false" aria-label="切换后台导航">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="adminNavbar">
                    <div class="navbar-nav me-auto">
                        <a class="nav-link" href="/">系统首页</a>
                        <a class="nav-link" href="/admin/users">用户管理</a>
                        <a class="nav-link" href="/admin/permissions">权限管理</a>
                        <a class="nav-link" href="/admin/operation-logs">操作日志</a>
                        <a class="nav-link" href="/admin/products">商品管理</a>
                        <a class="nav-link" href="/admin/orders">订单管理</a>
                        <a class="nav-link" href="/admin/statistics">统计报表</a>
                    </div>
                    <a class="btn btn-sm btn-outline-secondary" href="/account/login">切换账号</a>
                </div>
            </div>
        </nav>
    </header>
    <main class="container-fluid py-3">
        @RenderBody()
    </main>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
