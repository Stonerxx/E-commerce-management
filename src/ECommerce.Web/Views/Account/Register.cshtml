@{
    ViewData["Title"] = "注册";
}

<div class="row justify-content-center">
    <div class="col-12 col-md-7 col-lg-5">
        <div class="border rounded bg-white p-4 shadow-sm">
            <h1 class="h3 mb-2">用户注册</h1>
            <p class="text-muted mb-4">注册成功后自动分配普通用户角色 USER，并直接登录。</p>
            <form method="post" asp-action="RegisterPost">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                <div class="mb-3">
                    <label class="form-label" for="username">用户名</label>
                    <input class="form-control" id="username" name="username" autocomplete="username" required maxlength="50" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="password">密码</label>
                    <input class="form-control" id="password" name="password" type="password" autocomplete="new-password" required minlength="6" />
                    <div class="form-text">至少 6 位。</div>
                </div>
                <div class="mb-3">
                    <label class="form-label" for="phone">手机号</label>
                    <input class="form-control" id="phone" name="phone" autocomplete="tel" maxlength="20" />
                </div>
                <div class="mb-4">
                    <label class="form-label" for="email">邮箱</label>
                    <input class="form-control" id="email" name="email" type="email" autocomplete="email" maxlength="100" />
                </div>
                <div class="d-flex align-items-center gap-2">
                    <button class="btn btn-primary" type="submit">注册并登录</button>
                    <a class="btn btn-link" href="/account/login">已有账号，去登录</a>
                </div>
            </form>
        </div>
    </div>
</div>
