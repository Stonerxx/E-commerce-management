@{
    ViewData["Title"] = "注册";
}

<div class="auth-page">
    <div class="auth-shell">
        <div class="row g-0">
            <aside class="col-lg-5 auth-aside">
                <a class="app-brand text-white mb-5" href="/"><span class="brand-mark"><i class="bi bi-bag-heart-fill"></i></span><span><strong>电商管理系统DEMO</strong><small>JOIN US</small></span></a>
                <div class="page-kicker text-info">NEW MEMBER</div>
                <h1 class="display-6 fw-bold mb-3">开启你的购物旅程</h1>
                <p class="text-muted mb-4">注册后自动成为普通会员，可使用购物车、优惠券、地址、订单、支付、物流与评价服务。</p>
                <div class="vstack gap-3">
                    <div class="d-flex gap-3"><span class="quick-action-icon"><i class="bi bi-ticket-perforated"></i></span><div><strong>领取优惠</strong><div class="small text-muted">查看可领与已领取优惠券</div></div></div>
                    <div class="d-flex gap-3"><span class="quick-action-icon"><i class="bi bi-truck"></i></span><div><strong>订单可追踪</strong><div class="small text-muted">支付、发货、物流状态清晰可见</div></div></div>
                    <div class="d-flex gap-3"><span class="quick-action-icon"><i class="bi bi-star"></i></span><div><strong>分享评价</strong><div class="small text-muted">完成订单后提交真实使用体验</div></div></div>
                </div>
            </aside>
            <div class="col-lg-7 auth-form">
                <div class="mb-4"><div class="page-kicker">CREATE ACCOUNT</div><h2 class="h2 fw-bold mb-2">注册会员</h2><p class="text-muted mb-0">填写基础信息，手机号和邮箱可选</p></div>
                <form method="post" asp-action="RegisterPost">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger py-2" role="alert"></div>
                    <div class="mb-3"><label class="form-label fw-semibold" for="username">用户名</label><input class="form-control form-control-lg" id="username" name="username" autocomplete="username" required maxlength="50" placeholder="设置登录用户名" /></div>
                    <div class="mb-3"><label class="form-label fw-semibold" for="password">密码</label><div class="input-group input-group-lg"><input class="form-control" id="password" name="password" type="password" autocomplete="new-password" required minlength="6" placeholder="至少 6 位" /><button class="btn btn-outline-secondary" type="button" data-password-toggle="#password" aria-label="显示密码"><i class="bi bi-eye"></i></button></div></div>
                    <div class="row g-3 mb-4"><div class="col-md-6"><label class="form-label fw-semibold" for="phone">手机号 <span class="text-muted fw-normal">（选填）</span></label><input class="form-control" id="phone" name="phone" autocomplete="tel" maxlength="20" placeholder="用于联系与收货" /></div><div class="col-md-6"><label class="form-label fw-semibold" for="email">邮箱 <span class="text-muted fw-normal">（选填）</span></label><input class="form-control" id="email" name="email" type="email" autocomplete="email" maxlength="100" placeholder="name@example.com" /></div></div>
                    <button class="btn btn-primary btn-lg w-100 rounded-pill" type="submit">注册并登录 <i class="bi bi-arrow-right ms-1"></i></button>
                    <p class="text-center text-muted mt-4 mb-0">已有账号？<a class="fw-semibold text-decoration-none" href="/account/login">返回登录</a></p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector("[data-password-toggle]")?.addEventListener("click", function () {
            var input = document.querySelector(this.dataset.passwordToggle);
            var visible = input.type === "text";
            input.type = visible ? "password" : "text";
            this.innerHTML = visible ? '<i class="bi bi-eye"></i>' : '<i class="bi bi-eye-slash"></i>';
            this.setAttribute("aria-label", visible ? "显示密码" : "隐藏密码");
        });
    </script>
}
