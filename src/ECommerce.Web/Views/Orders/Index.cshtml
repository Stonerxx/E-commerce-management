@{
    Layout = "_Layout";
    ViewData["Title"] = "我的订单";
}

<div id="ordersApp" v-cloak>
    <div class="container py-4">
        <h1 class="h3 mb-4">我的订单</h1>

        <!-- 筛选 -->
        <div class="row g-3 mb-4">
            <div class="col-12 col-md-4">
                <select class="form-select" v-model="filters.status" v-on:change="loadOrders">
                    <option value="">全部状态</option>
                    <option value="0">待支付</option>
                    <option value="1">已支付</option>
                    <option value="2">已发货</option>
                    <option value="3">已完成</option>
                    <option value="4">已取消</option>
                </select>
            </div>
            <div class="col-12 col-md-8 text-md-end">
                <span class="text-muted small">共 {{ totalCount }} 条订单</span>
            </div>
        </div>

        <!-- 订单列表 -->
        <div v-if="loading" class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">加载中...</span>
            </div>
        </div>

        <div v-else-if="orders.length === 0" class="text-center py-5">
            <p class="text-muted">暂无订单</p>
        </div>

        <div v-else class="vstack gap-3">
            <div v-for="order in orders" v-bind:key="order.orderId" class="border rounded p-3 bg-white">
                <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-2">
                    <div>
                        <span class="text-muted small">订单号：</span>
                        <strong>{{ order.orderNo }}</strong>
                    </div>
                    <div>
                        <span class="badge" v-bind:class="getStatusBadge(order.status)">
                            {{ getStatusText(order.status) }}
                        </span>
                        <span class="text-muted small ms-2">¥{{ order.payAmount.toFixed(2) }}</span>
                    </div>
                </div>
                <div class="d-flex flex-wrap justify-content-between align-items-center">
                    <div class="text-muted small">
                        创建时间：{{ formatDate(order.createdAt) }}
                    </div>
                    <div class="d-flex gap-2">
                        <a v-bind:href="'/orders/' + order.orderId" class="btn btn-sm btn-outline-primary">查看详情</a>
                        <button v-if="order.status === 0" class="btn btn-sm btn-outline-danger" v-on:click="cancelOrder(order.orderId)">取消订单</button>
                        <button v-if="order.status === 2" class="btn btn-sm btn-outline-success" v-on:click="confirmOrder(order.orderId)">确认收货</button>
                        <button v-if="order.status === 0" class="btn btn-sm btn-primary" v-on:click="goPay(order.orderId)">去支付</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- 分页 -->
        <div v-if="totalPages > 1" class="mt-4">
            <nav>
                <ul class="pagination justify-content-center">
                    <li class="page-item" v-bind:class="{ disabled: pageIndex === 1 }">
                        <a class="page-link" href="#" v-on:click.prevent="goPage(pageIndex - 1)">上一页</a>
                    </li>
                    <li class="page-item" v-for="p in visiblePages" v-bind:key="p" v-bind:class="{ active: p === pageIndex }">
                        <a class="page-link" href="#" v-on:click.prevent="goPage(p)">{{ p }}</a>
                    </li>
                    <li class="page-item" v-bind:class="{ disabled: pageIndex === totalPages }">
                        <a class="page-link" href="#" v-on:click.prevent="goPage(pageIndex + 1)">下一页</a>
                    </li>
                </ul>
            </nav>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="~/js/orders.js" asp-append-version="true"></script>
}
