@using ECommerce.Domain.Enums
@model ECommerce.Web.Models.PaymentViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "模拟支付";

    var order = Model.Order;
    var payment = Model.Payment;
    var canPay = order.Status == (int)OrderStatus.PendingPayment
        && payment.Status is (int)PaymentStatus.Pending or (int)PaymentStatus.Failed;
    var statusText = order.Status switch
    {
        (int)OrderStatus.PendingPayment => "待支付",
        (int)OrderStatus.Paid => "已支付",
        (int)OrderStatus.Shipped => "已发货",
        (int)OrderStatus.Completed => "已完成",
        (int)OrderStatus.Cancelled => "已取消",
        _ => "未知"
    };
}

<div class="container py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-4">
        <div>
            <p class="text-uppercase text-muted small fw-semibold mb-1">PAYMENT</p>
            <h1 class="h3 mb-0">模拟支付</h1>
        </div>
        <a class="btn btn-outline-secondary" href="/orders">返回我的订单</a>
    </div>

    <div class="alert alert-info">
        本页使用模拟支付渠道，但会真实创建支付记录，并在同一事务内完成订单状态和库存扣减。
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notice))
    {
        <div class="alert alert-info">@Model.Notice</div>
    }

    <div class="row g-3">
        <div class="col-12 col-lg-8">
            <div class="border rounded bg-white p-3">
                <h2 class="h5 mb-3">订单支付信息</h2>
                <dl class="row mb-0">
                    <dt class="col-sm-3">订单号</dt>
                    <dd class="col-sm-9">@order.OrderNo</dd>
                    <dt class="col-sm-3">订单状态</dt>
                    <dd class="col-sm-9">@statusText</dd>
                    <dt class="col-sm-3">支付金额</dt>
                    <dd class="col-sm-9 text-danger fw-semibold">¥@order.PayAmount.ToString("F2")</dd>
                    <dt class="col-sm-3">支付记录</dt>
                    <dd class="col-sm-9">@payment.PaymentId</dd>
                    <dt class="col-sm-3">支付方式</dt>
                    <dd class="col-sm-9">@payment.PayMethod</dd>
                    <dt class="col-sm-3">交易流水</dt>
                    <dd class="col-sm-9">@(payment.TradeNo ?? "-")</dd>
                    <dt class="col-sm-3">支付截止</dt>
                    <dd class="col-sm-9">@order.PayExpireTime.ToString("yyyy-MM-dd HH:mm:ss")</dd>
                </dl>
            </div>
        </div>

        <div class="col-12 col-lg-4">
            <div class="border rounded bg-white p-3">
                <h2 class="h5 mb-3">演示操作</h2>
                @if (canPay)
                {
                    <form method="post" action="/payment/@order.OrderId/demo-pay">
                        @Html.AntiForgeryToken()
                        <button class="btn btn-primary w-100" type="submit">确认模拟支付</button>
                    </form>
                }
                else
                {
                    <p class="text-muted mb-0">当前支付已处理或订单状态不允许支付。</p>
                }
                <div class="d-grid gap-2 mt-3">
                    <a class="btn btn-outline-primary" href="/orders/@order.OrderId">查看订单详情</a>
                    <a class="btn btn-outline-secondary" href="/orders">返回订单列表</a>
                </div>
            </div>
        </div>
    </div>
</div>
