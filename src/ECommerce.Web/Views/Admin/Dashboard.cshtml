@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "数据概览";
}

<div id="dashboardApp" v-cloak>
    <!-- 顶部标题 -->
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <h1 class="display-5 fw-bold mb-1">数据概览</h1>
            <p class="text-muted mb-0">实时运营数据，<span v-text="lastUpdated"></span></p>
        </div>
        <button class="btn btn-outline-primary btn-sm" type="button" v-on:click="refreshAll" v-bind:disabled="loading">
            <span v-if="loading" class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
            <i class="fas fa-sync-alt me-1"></i> 刷新
        </button>
    </div>

    <!-- 五个统计卡片 -->
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-xl-5 g-3 mb-4">
        <div class="col" v-for="card in summaryCards" v-bind:key="card.key">
            <div class="card h-100 shadow-sm border-0">
                <div class="card-body d-flex align-items-center">
                    <div class="flex-shrink-0 me-3" v-html="card.icon" style="font-size: 2rem; color: var(--bs-primary);"></div>
                    <div class="flex-grow-1">
                        <p class="text-muted small mb-0">{{ card.label }}</p>
                        <p class="h4 mb-0 fw-bold">{{ card.value }}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- 图表 + 热销商品 两列布局 -->
    <div class="row g-3">
        <!-- 左侧：趋势图（宽列） -->
        <div class="col-12 col-xl-8">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">📈 近7日订单趋势</span>
                    <span class="text-muted small">按日统计</span>
                </div>
                <div class="card-body">
                    <div id="trendChart" style="width: 100%; height: 280px;"></div>
                </div>
            </div>
        </div>

        <!-- 右侧：热销商品 Top 10（窄列） -->
        <div class="col-12 col-xl-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">🏆 热销商品 Top 10</span>
                    <span class="text-muted small">按销售额</span>
                </div>
                <div class="card-body" style="max-height: 280px; overflow-y: auto;">
                    <div v-if="topProducts.length === 0" class="text-center text-muted py-3">
                        <i class="fas fa-box-open fs-4 d-block mb-2"></i>
                        暂无商品数据
                    </div>
                    <ul class="list-group list-group-flush" v-else>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2" v-for="(item, index) in topProducts" v-bind:key="item.productId">
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-secondary rounded-pill" style="min-width: 24px;">{{ index + 1 }}</span>
                                <span class="text-truncate" style="max-width: 120px;" v-text="item.productName"></span>
                            </div>
                            <span class="fw-semibold small">{{ item.salesCount }} 单</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
    <script src="~/js/admin-dashboard.js" asp-append-version="true"></script>
}