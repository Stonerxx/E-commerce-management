@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "权限管理";
}

<div id="adminPermissionsApp" v-cloak>
    <div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
        <div>
            <h1 class="h3 mb-1">角色权限绑定</h1>
            <p class="text-muted mb-0">选择角色后勾选权限，保存后写入 ROLE_PERMISSION 表并记录操作日志。</p>
        </div>
        <button class="btn btn-primary" type="button" v-on:click="save" v-bind:disabled="!selectedRoleId || saving">
            <span v-if="saving" class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
            保存绑定
        </button>
    </div>

    <div class="alert alert-danger" v-if="error">{{ error }}</div>
    <div class="alert alert-success" v-if="message">{{ message }}</div>

    <div class="row g-3">
        <div class="col-12 col-lg-3">
            <div class="border rounded bg-white p-3 shadow-sm">
                <h2 class="h6 mb-3">角色列表</h2>
                <div class="list-group">
                    <button class="list-group-item list-group-item-action" type="button"
                            v-for="role in roles"
                            v-bind:key="role.roleId"
                            v-bind:class="{ active: role.roleId === selectedRoleId }"
                            v-on:click="selectRole(role)">
                        <span class="fw-semibold">{{ role.roleName }}</span>
                        <span class="d-block small">{{ role.description || '-' }}</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-9">
            <div class="border rounded bg-white p-3 mb-3 shadow-sm">
                <label class="form-label" for="keyword">权限搜索</label>
                <div class="input-group">
                    <input class="form-control" id="keyword" v-model.trim="keyword" placeholder="权限名 / 资源路径 / 动作" />
                    <button class="btn btn-outline-secondary" type="button" v-on:click="loadPermissions">搜索</button>
                </div>
            </div>
            <div class="table-responsive border rounded bg-white shadow-sm">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 56px;">选择</th>
                            <th>ID</th>
                            <th>权限名</th>
                            <th>资源路径</th>
                            <th>动作</th>
                            <th>描述</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-if="permissions.length === 0">
                            <td class="text-center text-muted py-4" colspan="6">暂无权限数据</td>
                        </tr>
                        <tr v-for="permission in permissions" v-bind:key="permission.permissionId">
                            <td>
                                <input class="form-check-input" type="checkbox" v-bind:value="permission.permissionId" v-model="selectedPermissionIds" />
                            </td>
                            <td>{{ permission.permissionId }}</td>
                            <td>{{ permission.permName }}</td>
                            <td><code>{{ permission.resourcePath || '-' }}</code></td>
                            <td>{{ permission.action || '-' }}</td>
                            <td>{{ permission.description || '-' }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="~/js/admin-permissions.js" asp-append-version="true"></script>
}
