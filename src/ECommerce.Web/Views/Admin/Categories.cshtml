@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "分类管理";
}

<div id="categoriesApp" v-cloak>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h3 mb-1">分类管理</h1>
            <p class="text-muted mb-0">管理商品分类，支持树形结构、多级分类（最多5级）</p>
        </div>
        <button class="btn btn-primary" type="button" v-on:click="openCreateModal(null)">
            <i class="bi bi-plus-lg"></i> 新增根分类
        </button>
    </div>

    <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h2 class="h5 mb-0">分类列表</h2>
            <div class="d-flex align-items-center gap-3">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" id="showDisabledSwitch" v-model="showDisabled" v-on:change="loadCategories">
                    <label class="form-check-label small text-muted" for="showDisabledSwitch">显示已禁用</label>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div v-if="loading" class="text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">加载中...</span>
                </div>
            </div>

            <div v-else-if="loadError" class="text-center py-5">
                <div class="alert alert-danger d-inline-block text-start" style="max-width: 600px;">
                    <h6 class="alert-heading"><i class="bi bi-exclamation-triangle-fill"></i> 加载失败</h6>
                    <p class="mb-2 small">{{ loadError }}</p>
                    <button class="btn btn-sm btn-outline-danger" v-on:click="loadCategories">
                        <i class="bi bi-arrow-clockwise"></i> 重试
                    </button>
                </div>
            </div>

            <div v-else-if="flatTree.length === 0" class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                暂无分类数据，点击"新增根分类"开始创建
            </div>

            <table v-else class="table table-hover mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="min-width: 300px;">分类名称</th>
                        <th style="width: 80px;">层级</th>
                        <th style="width: 80px;">排序</th>
                        <th style="width: 100px;">状态</th>
                        <th style="width: 220px;">操作</th>
                    </tr>
                </thead>
                <tbody>
                    <tr v-for="item in flatTree" :key="item.node.categoryId">
                        <td>
                            <div class="d-inline-flex align-items-center" :style="{ paddingLeft: item.level * 24 + 'px' }">
                                <button v-if="item.hasChildren" type="button" class="btn btn-sm btn-link p-0 me-1 text-secondary" style="width: 20px;" v-on:click="toggleExpand(item.node)" title="展开/折叠">
                                    <i class="bi" :class="item.isExpanded ? 'bi-caret-down-fill' : 'bi-caret-right-fill'"></i>
                                </button>
                                <span v-else class="d-inline-block me-1" style="width: 20px;"></span>
                                <i class="bi me-1" :class="item.hasChildren ? 'bi-folder-fill text-warning' : 'bi-tag text-info'"></i>
                                <span class="fw-medium">{{ item.node.name }}</span>
                                <span v-if="item.node.treeLevel >= 5" class="badge bg-danger ms-2">满级</span>
                            </div>
                        </td>
                        <td>
                            <span class="badge bg-secondary">L{{ item.node.treeLevel }}</span>
                        </td>
                        <td class="text-muted">{{ item.node.sortOrder || 0 }}</td>
                        <td>
                            <span v-if="item.node.status === 1" class="badge bg-success">启用</span>
                            <span v-else class="badge bg-danger">禁用</span>
                        </td>
                        <td>
                            <div class="btn-group btn-group-sm">
                                <button v-if="item.node.treeLevel < 5" type="button" class="btn btn-outline-primary"
                                        data-action="create-child" :data-id="item.node.categoryId" v-on:click="handleButtonClick"
                                        title="新增子分类">
                                    <i class="bi bi-plus-lg"></i> 子分类
                                </button>
                                <button type="button" class="btn btn-outline-secondary"
                                        data-action="edit" :data-id="item.node.categoryId" v-on:click="handleButtonClick"
                                        title="编辑">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button type="button" class="btn btn-outline-danger"
                                        data-action="delete" :data-id="item.node.categoryId" v-on:click="handleButtonClick"
                                        title="删除">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-body py-2">
            <div class="d-flex align-items-center gap-4 text-muted small">
                <span><i class="bi bi-info-circle"></i> 最多支持5级分类</span>
                <span><i class="bi bi-exclamation-triangle"></i> 删除分类前需确保没有子分类和关联商品</span>
                <span><i class="bi bi-eye-slash"></i> 禁用的分类前台不会显示</span>
                <span><i class="bi bi-arrow-clockwise"></i> 点击三角图标可展开/收起子分类</span>
            </div>
        </div>
    </div>

    <div class="modal fade" id="categoryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        <i class="bi" :class="isEdit ? 'bi-pencil-square' : 'bi-plus-square'"></i>
                        {{ isEdit ? '编辑分类' : '新增分类' }}
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div v-if="errorMsg" class="alert alert-danger py-2">{{ errorMsg }}</div>
                    <form v-on:submit.prevent="saveCategory" novalidate>
                        <div class="mb-3">
                            <label class="form-label">分类名称 <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" v-model="form.name" placeholder="请输入分类名称">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">排序</label>
                            <input type="text" class="form-control" v-model="form.sortOrder" placeholder="数字越小越靠前">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">图标 URL</label>
                            <input type="text" class="form-control" v-model="form.iconUrl" placeholder="可选，分类图标地址">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">状态</label>
                            <select class="form-select" v-model="form.status">
                                <option value="1">启用</option>
                                <option value="0">禁用</option>
                            </select>
                        </div>
                        <div v-if="form.parentId" class="alert alert-info py-2 small">
                            <i class="bi bi-info-circle"></i>
                            将在上级分类（层级 {{ form.treeLevel - 1 }}）下创建第 {{ form.treeLevel }} 级子分类
                        </div>
                        <div class="d-flex justify-content-end gap-2">
                            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">取消</button>
                            <button type="submit" class="btn btn-primary" :disabled="submitting">
                                <span v-if="submitting" class="spinner-border spinner-border-sm"></span>
                                {{ isEdit ? '保存修改' : '创建分类' }}
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="~/js/admin-categories.js" asp-append-version="true"></script>
}
