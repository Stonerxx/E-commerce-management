@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "评价审核";
}

<div id="adminReviewsApp" v-cloak>
    <div class="mb-4"><h1 class="h3 mb-1">评价审核</h1><p class="text-muted mb-0">审核用户评价并同步刷新商品评分。</p></div>
    <div class="card mb-4"><div class="card-body"><div class="row g-2">
        <div class="col-md-4"><input class="form-control" type="number" v-model="filters.productId" placeholder="商品 ID" /></div>
        <div class="col-md-4"><select class="form-select" v-model="filters.status"><option value="">全部状态</option><option value="0">待审核</option><option value="1">已发布</option><option value="2">已屏蔽</option></select></div>
        <div class="col-md-2"><button class="btn btn-primary w-100" v-on:click="search">查询</button></div>
    </div></div></div>

    <div v-if="loading" class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    <div v-else class="vstack gap-3">
        <div v-for="item in items" v-bind:key="item.reviewId" class="card"><div class="card-body">
            <div class="d-flex flex-wrap justify-content-between gap-2">
                <div><strong>评价 #{{ item.reviewId }}</strong><span class="text-muted ms-2">订单 {{ item.orderId }} / 商品 {{ item.productId }}</span></div>
                <span class="badge" v-bind:class="statusClass(item.status)">{{ statusText(item.status) }}</span>
            </div>
            <div class="text-warning my-2"><span v-for="n in 5" v-bind:key="n">{{ n <= item.rating ? '★' : '☆' }}</span><span class="text-muted ms-2">{{ item.isAnonymous ? '匿名用户' : '用户 ' + item.userId }}</span></div>
            <p class="mb-2">{{ item.content || '用户未填写文字评价' }}</p>
            <div v-if="item.images.length" class="d-flex flex-wrap gap-2 mb-3"><a v-for="image in item.images" v-bind:key="image" v-bind:href="image" target="_blank"><img v-bind:src="image" alt="评价图片" style="width:72px;height:72px;object-fit:cover" class="rounded border" /></a></div>
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-2"><small class="text-muted">{{ formatDate(item.createdAt) }}</small><div><button class="btn btn-sm btn-outline-success me-2" v-if="item.status !== 1" v-on:click="setStatus(item, 1)">发布</button><button class="btn btn-sm btn-outline-danger" v-if="item.status !== 2" v-on:click="setStatus(item, 2)">屏蔽</button></div></div>
        </div></div>
        <div v-if="items.length === 0" class="text-center text-muted py-5">暂无评价</div>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-4"><span class="text-muted">共 {{ totalCount }} 条</span><div><button class="btn btn-sm btn-outline-secondary me-2" v-on:click="goPage(pageIndex - 1)" v-bind:disabled="pageIndex <= 1">上一页</button><span>{{ pageIndex }} / {{ totalPages }}</span><button class="btn btn-sm btn-outline-secondary ms-2" v-on:click="goPage(pageIndex + 1)" v-bind:disabled="pageIndex >= totalPages">下一页</button></div></div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="~/js/admin-reviews.js" asp-append-version="true"></script>
}
