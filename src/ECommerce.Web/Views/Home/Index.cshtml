@{
    ViewData["Title"] = "首页";
    var isAuthenticated = User.Identity?.IsAuthenticated == true;
    var isCustomer = User.IsInRole(ECommerce.Shared.Constants.AuthConstants.Roles.User);
    var canUseAdmin = User.IsInRole(ECommerce.Shared.Constants.AuthConstants.Roles.Service)
        || User.IsInRole(ECommerce.Shared.Constants.AuthConstants.Roles.Admin);
}

<div class="home-page py-4">
    <section class="border rounded bg-light p-4 p-lg-5 mb-4">
        <div class="row align-items-center g-4">
            <div class="col-lg-8">
                <p class="text-uppercase text-muted small fw-semibold mb-2">ECommerce Management</p>
                <h1 class="display-6 fw-semibold mb-3">电商购物平台</h1>
                <p class="lead text-muted mb-0">
                    服务器部署成功后可以从这里进入当前账号可用的页面。
                    普通用户看到购物流程，客服和管理员看到后台入口，未登录时先进入登录页。
                </p>
            </div>
            <div class="col-lg-4">
                <div class="d-grid gap-2">
                    @if (!isAuthenticated)
                    {
                        <a class="btn btn-primary btn-lg" href="/account/login">登录演示账号</a>
                        <a class="btn btn-outline-success btn-lg" href="/account/register">注册</a>
                    }
                    @if (isCustomer)
                    {
                        <a class="btn btn-primary btn-lg" href="/cart">进入购物车</a>
                        <a class="btn btn-outline-primary btn-lg" href="/orders">查看我的订单</a>
                    }
                    @if (canUseAdmin)
                    {
                        <a class="btn btn-primary btn-lg" href="/admin/orders">后台订单管理</a>
                        <a class="btn btn-outline-secondary btn-lg" href="/admin">后台首页</a>
                    }
                </div>
            </div>
        </div>
    </section>

    <div class="row g-3 mb-4">
        @if (isCustomer)
        {
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100 bg-white">
                    <h2 class="h5">前台用户</h2>
                    <p class="text-muted small">面向普通用户的购物、结算和订单页面。</p>
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-primary" href="/cart">购物车</a>
                        <a class="btn btn-outline-primary" href="/orders">我的订单</a>
                    </div>
                </div>
            </div>
        }

        @if (canUseAdmin)
        {
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100 bg-white">
                    <h2 class="h5">后台管理</h2>
                    <p class="text-muted small">面向客服和管理员的后台入口。</p>
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-secondary" href="/admin">后台首页</a>
                        <a class="btn btn-outline-secondary" href="/admin/orders">订单管理</a>
                    </div>
                </div>
            </div>
        }

        @if (!isAuthenticated)
        {
            <div class="col-md-6 col-xl-3">
                <div class="border rounded p-3 h-100 bg-white">
                    <h2 class="h5">账号入口</h2>
                    <p class="text-muted small">登录和注册页面仍保留统一入口。</p>
                    <div class="d-grid gap-2">
                        <a class="btn btn-outline-success" href="/account/login">登录</a>
                        <a class="btn btn-outline-success" href="/account/register">注册</a>
                    </div>
                </div>
            </div>
        }

        <div class="col-md-6 col-xl-3">
            <div class="border rounded p-3 h-100 bg-white">
                <h2 class="h5">系统检查</h2>
                <p class="text-muted small">部署后优先确认服务和数据库连接。</p>
                <div class="d-grid gap-2">
                    <a class="btn btn-outline-dark" href="/health">健康检查</a>
                    <a class="btn btn-outline-dark" href="/api/v1/system/db-check">数据库检查</a>
                </div>
            </div>
        </div>
    </div>

    <section class="border rounded p-3 mb-4">
        <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
            <div>
                <h2 class="h5 mb-1">开发文档</h2>
                <p class="text-muted mb-0">需要确认分支、接口、权限和页面路由时，可以直接打开这些文档。</p>
            </div>
            <div class="d-flex flex-wrap gap-2 align-items-start">
                <a class="btn btn-sm btn-outline-secondary" href="/docs/team-guide">组员开工指南</a>
                <a class="btn btn-sm btn-outline-secondary" href="/docs/development-spec">开发规范</a>
                <a class="btn btn-sm btn-outline-secondary" href="/docs/demo-flow">演示流程</a>
            </div>
        </div>
    </section>
</div>
