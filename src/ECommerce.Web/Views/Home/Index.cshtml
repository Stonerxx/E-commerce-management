@{
    ViewData["Title"] = "用户权限模块";
}

<section class="py-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-4">
        <div>
            <p class="text-primary fw-semibold mb-2">第 2 人负责模块</p>
            <h1 class="display-6 fw-semibold mb-3">用户、权限、地址、操作日志</h1>
            <p class="lead text-muted mb-0">
                本模块已接入注册登录、角色分配、权限绑定、收货地址管理和管理员操作日志查询。
            </p>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary" href="/account/login">登录</a>
            <a class="btn btn-outline-primary" href="/account/register">注册</a>
            <a class="btn btn-outline-secondary" href="/addresses">我的地址</a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="border rounded bg-white p-3 h-100">
                <div class="text-muted small mb-1">认证</div>
                <h2 class="h5">注册 / 登录</h2>
                <p class="mb-3 text-muted">普通用户注册后自动分配 USER 角色，登录后写入 Cookie。</p>
                <a href="/account/login">打开登录页</a>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="border rounded bg-white p-3 h-100">
                <div class="text-muted small mb-1">RBAC</div>
                <h2 class="h5">用户角色</h2>
                <p class="mb-3 text-muted">管理员可查询用户、启用禁用账号、为用户分配角色。</p>
                <a href="/admin/users">后台用户管理</a>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="border rounded bg-white p-3 h-100">
                <div class="text-muted small mb-1">权限</div>
                <h2 class="h5">角色权限绑定</h2>
                <p class="mb-3 text-muted">维护 ROLE、PERMISSION、ROLE_PERMISSION 的绑定关系。</p>
                <a href="/admin/permissions">后台权限管理</a>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="border rounded bg-white p-3 h-100">
                <div class="text-muted small mb-1">审计</div>
                <h2 class="h5">操作日志</h2>
                <p class="mb-3 text-muted">记录管理员关键写操作，支持按模块、人员、时间筛选。</p>
                <a href="/admin/operation-logs">查看操作日志</a>
            </div>
        </div>
    </div>

    <div class="row g-3">
        <div class="col-12 col-lg-7">
            <div class="border rounded bg-white p-3 h-100">
                <h2 class="h5 mb-3">验收入口</h2>
                <div class="list-group list-group-flush">
                    <a class="list-group-item list-group-item-action d-flex justify-content-between" href="/account/register">
                        <span>注册页面</span><code>/account/register</code>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between" href="/account/login">
                        <span>登录页面</span><code>/account/login</code>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between" href="/addresses">
                        <span>收货地址管理</span><code>/addresses</code>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between" href="/admin/users">
                        <span>后台用户角色管理</span><code>/admin/users</code>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between" href="/admin/permissions">
                        <span>后台角色权限绑定</span><code>/admin/permissions</code>
                    </a>
                    <a class="list-group-item list-group-item-action d-flex justify-content-between" href="/admin/operation-logs">
                        <span>管理员操作日志</span><code>/admin/operation-logs</code>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-5">
            <div class="border rounded bg-white p-3 h-100">
                <h2 class="h5 mb-3">接口状态</h2>
                <ul class="mb-0">
                    <li><code>POST /api/v1/auth/register</code></li>
                    <li><code>POST /api/v1/auth/login</code></li>
                    <li><code>GET|POST /api/v1/addresses</code></li>
                    <li><code>PUT|DELETE /api/v1/addresses/{addressId}</code></li>
                    <li><code>GET /api/v1/admin/users</code></li>
                    <li><code>PUT /api/v1/admin/users/{userId}/roles</code></li>
                    <li><code>GET|PUT /api/v1/admin/permissions/roles/{roleId}</code></li>
                    <li><code>GET /api/v1/admin/operation-logs</code></li>
                </ul>
            </div>
        </div>
    </div>
</section>
