@{
    Layout = "_Layout";
    ViewData["Title"] = "我的购物车";
}

<div id="cartApp" v-cloak>
    <div class="container py-4">
        <h1 class="h3 mb-4">我的购物车</h1>

        <!-- 空状态 -->
        <div v-if="items.length === 0" class="text-center py-5">
            <p class="text-muted">购物车是空的，去逛逛吧！</p>
            <a href="/products" class="btn btn-primary">去购物</a>
        </div>

        <!-- 购物车列表 -->
        <div v-else>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>
                                <input type="checkbox" v-model="allSelected" v-on:change="toggleAll" />
                            </th>
                            <th>商品信息</th>
                            <th class="text-center">单价</th>
                            <th class="text-center">数量</th>
                            <th class="text-end">小计</th>
                            <th class="text-center">操作</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr v-for="item in items" v-bind:key="item.cartItemId">
                            <td>
                                <input type="checkbox" v-model="item.selected" v-on:change="updateItem(item)" />
                            </td>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <img v-bind:src="item.mainImage || '/images/default-product.jpg'" alt="商品图片" class="img-thumbnail" style="width:60px;height:60px;object-fit:cover;" />
                                    <div>
                                        <a v-bind:href="'/products/' + item.productId" class="text-decoration-none">
                                            <strong>{{ item.productName }}</strong>
                                        </a>
                                        <p class="text-muted small mb-0">{{ item.specDescJson }}</p>
                                    </div>
                                </div>
                            </td>
                            <td class="text-center">¥{{ item.unitPrice.toFixed(2) }}</td>
                            <td class="text-center">
                                <div class="input-group input-group-sm" style="width:120px;margin:0 auto;">
                                    <button class="btn btn-outline-secondary" type="button" v-on:click="decreaseQuantity(item)">-</button>
                                    <input type="number" class="form-control text-center" v-model.number="item.quantity" min="1" v-on:change="updateItem(item)" />
                                    <button class="btn btn-outline-secondary" type="button" v-on:click="increaseQuantity(item)">+</button>
                                </div>
                            </td>
                            <td class="text-end">¥{{ (item.unitPrice * item.quantity).toFixed(2) }}</td>
                            <td class="text-center">
                                <button class="btn btn-sm btn-outline-danger" v-on:click="removeItem(item.cartItemId)">删除</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- 底部结算 -->
            <div class="border-top pt-3 mt-3">
                <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div>
                        <span>已选 <strong>{{ selectedCount }}</strong> 件商品</span>
                        <span class="ms-3">合计：<strong class="text-danger">¥{{ selectedTotal.toFixed(2) }}</strong></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button class="btn btn-outline-secondary" v-on:click="clearCart">清空</button>
                        <button class="btn btn-primary" v-bind:disabled="selectedCount === 0" v-on:click="checkout">去结算</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/vue@3/dist/vue.global.prod.js"></script>
    <script src="~/js/cart.js" asp-append-version="true"></script>
}
